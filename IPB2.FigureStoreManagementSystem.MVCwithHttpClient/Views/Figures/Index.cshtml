@model IReadOnlyList<IPB2.FigureStoreManagementSystem.MVCwithHttpClient.Models.FigureViewModel>

<h1>Figure Catalog</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Price</th>
            <th>Stock</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var figure in Model)
    {
        <tr>
            <td>@figure.FigureName</td>
            <td>@figure.CategoryName</td>
            <td>@figure.Price</td>
            <td>@figure.Stock</td>
        </tr>
    }
    </tbody>
</table>
